// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users{
  id Int @id @default(autoincrement())
  username String @unique
  full_name String @unique
  email String @unique
  password String
  photo_profile String @unique
  bio String
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  following Following[] @relation("userFollowing")
  follower Following[] @relation("userFollower")
  threads_created Threads[] @relation("UserThreadsCreated")
  threads Threads[] @relation("UserThreadsUpdated")
  likes_id Likes[] @relation("UsersToLikesId")
  likes_name Likes[] @relation("UsersToLikesCreatedName")
  replierName Replies[] @relation("ReplierName")
  updaterName Replies[] @relation("UpdaterName")
  threadsCreatorPic Threads[] @relation("UserThreadProfilePic")
  threadReplies Replies[] @relation("UserReplyProfilePic")
  likesReplieId LikesReplies[] @relation("UsersToLikesRepliesId")
  likesReplieCreatedByName LikesReplies[] @relation("UsersToLikesRepliesCreatedByName")
  threadsCreatorId Threads[] @relation("CreatorId")
  repliesCreatorId Replies[] @relation("replyCreatorId")
}

model Following{
  id Int @id @default(autoincrement())
  following Users @relation("userFollowing",fields: [following_id], references: [id], onDelete: Cascade)
  following_id Int
  follower Users @relation("userFollower", fields: [follower_id], references: [id], onDelete: Cascade)
  follower_id Int
  create_at DateTime @default(now())
  updated_at DateTime?
}

model Threads{
  id Int @id @default(autoincrement())
  content String
  image String?
  created_at DateTime @default(now())
  creator_pic Users? @relation("UserThreadProfilePic", fields: [creator_photo_profile], references: [photo_profile], onDelete: Cascade)
  creator_photo_profile String?
  thread_created Users @relation("UserThreadsCreated",fields: [created_by], references: [username], onDelete: Cascade)
  created_by String
  creator Users? @relation("CreatorId", fields: [creator_id], references: [id], onDelete: Cascade)
  creator_id Int
  updated_at DateTime? @updatedAt
  thread_updated Users? @relation("UserThreadsUpdated", fields: [updated_by], references: [username], onDelete: Cascade)
  updated_by String?
  likes Likes[] @relation("ThreadsToLikesId")
  replies Replies[] @relation("ThreadReplied")
}

model Likes{
  id Int @id @default(autoincrement())
  user_likes Users @relation("UsersToLikesId", fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int
  thread_likes Threads @relation("ThreadsToLikesId", fields: [thread_id], references: [id], onDelete: Cascade)
  thread_id Int
  created_at DateTime @default(now())
  likes_created Users @relation("UsersToLikesCreatedName", fields: [created_by], references: [username], onDelete: Cascade)
  created_by String
}

model Replies{
  id Int @id @default(autoincrement())
  threadReplied Threads @relation("ThreadReplied", fields: [thread_id], references: [id], onDelete: Cascade)
  thread_id Int
  image String?
  content String
  created_at DateTime @default(now())
  replierName Users @relation("ReplierName", fields: [created_by], references: [username], onDelete: Cascade)
  created_by String
  creator_pic Users? @relation("UserReplyProfilePic", fields: [creator_photo_profile], references: [photo_profile], onDelete: Cascade)
  creator_photo_profile String?
  creator Users @relation("replyCreatorId", fields: [creator_id], references: [id], onDelete: Cascade)
  creator_id Int
  updated_at DateTime? @updatedAt
  updaterName Users? @relation("UpdaterName", fields: [updated_by], references: [username], onDelete: Cascade)
  updated_by String?
  likesReplies LikesReplies[] @relation("RepliesToLikesRepliesId")
}

model LikesReplies{
  id Int @id @default(autoincrement())
  user_likes Users @relation("UsersToLikesRepliesId", fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int
  replie_likes Replies @relation("RepliesToLikesRepliesId", fields: [replie_id], references: [id], onDelete: Cascade)
  replie_id Int
  created_at DateTime @default(now())
  likesReply_created Users @relation("UsersToLikesRepliesCreatedByName", fields: [created_by], references: [username], onDelete: Cascade)
  created_by String
}